# Single source of version truth for the stealth-Chromium build pipeline.
# Sourced by build/run-build.sh and the validate/ harness.

# Chromium / ungoogled-chromium base.
CHROMIUM_VERSION=148.0.7778.96
UC_TAG=148.0.7778.96-1                              # ungoogled-chromium git tag

# clark-browser reference we validate the amd64 parity build against. Our
# patches/ were forked VERBATIM from this tag (24 .patch + 000-shared). This is
# also the exact binary cuttle ships today (ops/docker/Dockerfile), so a
# zero-surface-diff parity result means our pipeline reproduces production.
#
# NOTE: patches 0027 (analyser-node-noise) and 0047 (suppress-cdc-globals) were
# added to clark AFTER this tag and are NOT in our series - the stealth5 binary
# was built without them. They are available to cherry-pick for a future
# shipping build (a deliberate, documented divergence; see README).
CLARK_REF_TAG=chromium-v148.0.7778.96-stealth5
CLARK_REF_ASSET=clark-browser-linux-x64.tar.gz
CLARK_REF_SHA256=30cca952d11d94ca3424ac184b100c88ba686bfb87f2aaf4668ac5767562bd67
CLARK_REF_URL=https://github.com/clark-labs-inc/clark-browser/releases/download/chromium-v148.0.7778.96-stealth5/clark-browser-linux-x64.tar.gz

# Our own published bundles (GitHub release on glim-sh/cuttle). Pinned by
# sha256 once Phase 4 publishes them; consumed by ops/docker/Dockerfile.
BROWSER_RELEASE_TAG=browser-v148.0.7778.96-1
BROWSER_ASSET_X64=stealth-chromium-linux-x64.tar.gz
BROWSER_ASSET_ARM64=stealth-chromium-linux-arm64.tar.gz
BROWSER_SHA256_X64=
BROWSER_SHA256_ARM64=

# sccache cache cap on the mounted volume (both targets' worth).
SCCACHE_CACHE_SIZE=150G
